# Copie para .env e troque os valores antes de colocar online.
PORT=3000

# Senha que os mods usam para entrar no painel.
MOD_PASSWORD=troca-essa-senha

# Token secreto que vai na URL do overlay no OBS.
# Mantenha em segredo: quem tiver o link consegue ver seu overlay.
OVERLAY_TOKEN=overlay-secreto

# (Opcional) Cloudinary — armazenamento gratuito e persistente dos uploads.
# Sem isto, o upload salva na pasta local /media (bom para dev, mas o disco
# do Render/Railway é efêmero e some no deploy).
# Pegue o valor em: Cloudinary > Dashboard > "API Environment variable".
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
