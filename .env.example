# Copie para .env e troque os valores antes de colocar online.
PORT=3000

# Senha que os mods usam para entrar no painel.
MOD_PASSWORD=troca-essa-senha

# Token secreto que vai na URL do overlay no OBS.
# Mantenha em segredo: quem tiver o link consegue ver seu overlay.
OVERLAY_TOKEN=overlay-secreto
